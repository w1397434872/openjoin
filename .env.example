# OpenAI 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# 可选：自定义模型参数
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ============================================
# 向量数据库 (Milvus) 配置
# ============================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=join_agent

# Embedding 模型路径
EMBEDDING_MODEL_PATH=milvus/embedding_model/iic/nlp_corom_sentence-embedding_chinese-base

# 是否启用向量记忆
ENABLE_VECTOR_MEMORY=true

# ============================================
# 文本记忆 (MemoryManager) 配置
# ============================================
# 最大对话轮数
MEMORY_MAX_TURNS=15

# 最大字符数 (1万字 = 10000)
MEMORY_MAX_CHARS=10000

# 摘要轮数 (前N轮生成摘要)
MEMORY_SUMMARY_TURNS=10

# 保留轮数 (后N轮保留完整)
MEMORY_KEEP_TURNS=5

# 摘要最大字符数
MEMORY_SUMMARY_MAX_CHARS=100

# 是否启用文本记忆
ENABLE_MEMORY=true

# ============================================
# 向量记忆相似度阈值配置
# ============================================
# 相似度阈值 (0.0 - 1.0)，只有相似度大于等于此值的记忆才会被使用
VECTOR_MEMORY_SIMILARITY_THRESHOLD=0.7
